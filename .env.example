# Copy this file to .env and adjust values as needed.
# The backend reads these via os.getenv() with safe local-dev defaults,
# so the app runs without a .env file too - but set these for anything
# beyond local development.

# SQLite by default (zero setup). For production, use a Postgres URL,
# e.g. a Neon connection string: postgresql://user:pass@host/dbname
DATABASE_URL=sqlite:///./merchaudit.db

# Used to sign JWTs. MUST be changed to a long random value outside
# local development - the checked-in default is intentionally insecure.
JWT_SECRET=dev-only-insecure-secret-change-me

# Comma-separated list of origins allowed to call the API (CORS).
FRONTEND_ORIGINS=http://localhost:8501

# Directory containing the trained model artifacts (isolation_forest.joblib,
# scaler.joblib, metadata.json). Produced by backend/ml/train_model.py.
MODEL_DIR=models/current
